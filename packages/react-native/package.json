{
	"name": "@hyperserve/upload-react-native",
	"version": "0.1.0",
	"author": "Ryan Trann",
	"description": "Composable React Native UI components for @hyperserve/upload",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/hyper-serve/upload.git",
		"directory": "packages/react-native"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": ["video", "upload", "react-native", "mobile", "components"],
	"scripts": {
		"build": "tsc",
		"build:watch": "tsc --watch",
		"test": "jest",
		"test:watch": "jest --watch",
		"typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
		"clean": "rm -rf dist",
		"prepublishOnly": "bun run build"
	},
	"peerDependencies": {
		"@hyperserve/upload": ">=0.1.0",
		"react": ">=18.0.0",
		"react-native": ">=0.73.0"
	},
	"devDependencies": {
		"@hyperserve/upload": "workspace:*",
		"@react-native/babel-preset": "^0.84.1",
		"@testing-library/react-native": "^13.3.1",
		"@types/jest": "^29.5.14",
		"@types/react": "19.2.14",
		"babel-jest": "^29.7.0",
		"jest": "^29.7.0",
		"react": "19.2.0",
		"react-native": "0.84.1",
		"react-test-renderer": "19.2.0",
		"typescript": "5.9.3"
	}
}

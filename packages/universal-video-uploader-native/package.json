{
	"name": "@hyperserve/universal-video-uploader-native",
	"version": "0.0.1",
	"author": "Ryan Trann",
	"description": "Composable React Native UI components for @hyperserve/universal-video-uploader",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"build:watch": "tsc --watch",
		"prepublishOnly": "bun run build"
	},
	"peerDependencies": {
		"@hyperserve/universal-video-uploader": ">=0.0.1",
		"react": ">=18.0.0",
		"react-native": ">=0.73.0"
	},
	"devDependencies": {
		"@hyperserve/universal-video-uploader": "workspace:*",
		"@types/react": "19.2.14",
		"react": "19.2.0",
		"react-native": "0.83.2",
		"typescript": "5.9.3"
	}
}
